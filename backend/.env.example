# Copy this file to .env and fill in your actual Gemini API key.
# Get a key from: https://aistudio.google.com/app/apikey
#
# This file (.env) is loaded server-side only - the key never gets
# sent to the browser. The frontend calls YOUR backend's /api/chat
# endpoint, and the backend calls Gemini using this key.

GEMINI_API_KEY=your-gemini-api-key-here

# Optional - defaults to gemini-2.5-flash if not set
GEMINI_MODEL=gemini-2.5-flash
